{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": false,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "*.js", "*.vue"],
  "exclude": ["node_modules", "dist"]
}
